  "About_Section": [
    {
      "ID": "1",
      "Paragraph_1_Lead": "The Conference of Religious Women India (CRWI), in collaboration with the Global Research Network (GRN), is delighted to invite you to this Symposium.",
      "Paragraph_2": "For centuries, consecrated women have embodied Christ’s tenderness through ministries of education, pastoral care, healthcare, formation, social outreach, eldercare, ecological stewardship, and media engagement. Their fidelity and service continue to illuminate challenging realities with courage, creativity, and unwavering hope.",
      "Paragraph_3": "This Symposium will offer a platform for sharing research insights, personal narratives, and collaborative reflections on the evolving mission of Consecrated Women amid contemporary global changes.",
      "Quote_Text": "\"Consecrated life is a living memory of Jesus’ way of being – a sign that love, when lived radically, can transform the world.\"",
      "Quote_Author": "— Pope Francis"
    }
  ],
  "Leadership_Messages": [
    {
      "ID": "1",
      "Name": "Sr. Maria Nirmalini AC",
      "Role": "Message from the President",
      "Role_Company": "President, CRWI",
      "Message_Text": "\"It is with great joy and hope that we welcome you to this symposium. As we gather to reflect on our consecrated life, let us be open to the Spirit's leading, renewed in our commitment to be living flames of God's love in a world that yearns for hope.\"",
      "Image_Path": "images/Leaders/Sr. Maria Nirmalini AC.jpeg"
    },
    {
      "ID": "2",
      "Name": "Sr. Molly Mathew MSMHC",
      "Role": "Message from the Executive Director",
      "Role_Company": "Executive Director, CRWI",
      "Message_Text": "\"This symposium is a milestone in our journey together. It is an opportunity to celebrate our shared mission, to learn from one another, and to chart a path forward that is sustainable, inclusive, and deeply rooted in our charism.\"",
      "Image_Path": "images/Leaders/Sr. Molly Mathew MSMHC.png"
    }
  ],
